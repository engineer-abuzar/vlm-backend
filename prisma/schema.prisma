// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

enum SessionType {
  CHAT
  AUDIO
  VIDEO
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model OTP {
  id         String   @id @default(uuid())
  identifier String   @unique
  otp        String
  expiresAt  DateTime
  verified   Boolean  @default(false)
}

model Subjects {
  id    String @id @default(uuid())
  name  String
  
  class String
  code  String @unique

  chapters  Chapters[]
  doubts    Doubt[]
  mcqQuestions McqQuestion[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Chapters {
  id        String @id @default(uuid())
  name      String
  subjectId String

  subject Subjects @relation(fields: [subjectId], references: [id])
  doubts  Doubt[]
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  mobile   String? @unique
  password String?
  role     Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?

  wallet Wallet?
  supportTickets SupportTicket[]
  referralsGiven Referral[] @relation("ReferrerReferrals")
  referralsReceived Referral[] @relation("RefereeReferrals")
}

model Plan {
  id                String           @unique @default(uuid())
  name              String
  price             Float
  duration          String
  credits           String
  humanChatCredits  String
  audioVideoMinutes String
  liveClassAcess    String
  studentProfiles   StudentProfile[]
  payments          Payment[]
  subscriptions     Subscription[]
}

model StudentProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  planId     String?
  fullName   String
  nickname   String?
  className  String?
  board      String?
  schoolName String?
  city       String?
  state      String?

  plan Plan? @relation(fields: [planId], references: [id])
  user User @relation(fields: [userId], references: [id])

  sessions Session[] @relation("StudentSessions")
  doubts Doubt[] @relation("StudentDoubts")
  chats Chat[] @relation("StudentChats")
  payments Payment[] @relation("StudentPayments")
  subscription Subscription? @relation("StudentSubscription")
  feedbacks Feedback[]
  mcqAttempts McqAttempt[]
}

model TeacherProfile {
  id     String @id @default(uuid())
  userId String @unique

  fullName      String
  qualification String?
  experience    Int?
  rating        Float   @default(0)

  user User @relation(fields: [userId], references: [id])

  sessions Session[] @relation("TeacherSessions")
  doubts Doubt[] @relation("TeacherDoubts")
  chats Chat[] @relation("TeacherChats")
}

model ParentProfile {
  id       String @id @default(uuid())
  userId   String @unique
  fullName String

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id      String @id @default(uuid())
  userId  String @unique
  balance Float  @default(0)

  user User @relation(fields: [userId], references: [id])
}

enum DoubtStatus {
  PENDING
  ASSIGNED
  RESOLVED
  CLOSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Doubt {
  id          String       @id @default(uuid())
  studentId   String
  subjectId   String?
  chapterId   String?
  text        String?
  images      String[]
  status      DoubtStatus  @default(PENDING)
  assignedTo  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  student     StudentProfile @relation("StudentDoubts", fields: [studentId], references: [id])
  subject     Subjects?    @relation(fields: [subjectId], references: [id])
  chapter     Chapters?    @relation(fields: [chapterId], references: [id])
  teacher     TeacherProfile? @relation("TeacherDoubts", fields: [assignedTo], references: [id])
  messages    Message[]    @relation("DoubtMessages")
  feedback    Feedback?
}

model Chat {
  id         String    @id @default(uuid())
  studentId  String
  teacherId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  student    StudentProfile @relation("StudentChats", fields: [studentId], references: [id])
  teacher    TeacherProfile? @relation("TeacherChats", fields: [teacherId], references: [id])
  messages   Message[]   @relation("ChatMessages")
}

model Message {
  id         String    @id @default(uuid())
  chatId     String?
  doubtId    String?
  senderId   String
  senderType Role
  content    String
  images     String[]
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  chat       Chat?     @relation("ChatMessages", fields: [chatId], references: [id])
  doubt      Doubt?    @relation("DoubtMessages", fields: [doubtId], references: [id])
}

model Payment {
  id              String        @id @default(uuid())
  studentId       String
  planId          String
  amount          Float
  currency        String        @default("INR")
  razorpayOrderId String?
  razorpayPaymentId String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  student         StudentProfile @relation("StudentPayments", fields: [studentId], references: [id])
  plan            Plan          @relation(fields: [planId], references: [id])
  subscription    Subscription?
}

model Subscription {
  id         String             @id @default(uuid())
  studentId  String             @unique
  planId     String
  paymentId  String?            @unique
  startDate  DateTime
  endDate    DateTime
  status     SubscriptionStatus @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  student    StudentProfile     @relation("StudentSubscription", fields: [studentId], references: [id])
  plan       Plan               @relation(fields: [planId], references: [id])
  payment    Payment?           @relation(fields: [paymentId], references: [id])
}

model Feedback {
  id         String   @id @default(uuid())
  sessionId  String?  @unique
  doubtId    String?  @unique
  studentId  String
  rating     Int      @db.SmallInt
  comment    String?
  createdAt  DateTime @default(now())

  session    Session? @relation(fields: [sessionId], references: [id])    
  doubt      Doubt?   @relation(fields: [doubtId], references: [id])      
  student    StudentProfile @relation(fields: [studentId], references: [id])
}

model SupportTicket {
  id          String        @id @default(uuid())
  userId      String
  subject     String
  description String
  status      TicketStatus  @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id]) 
}

model Session {
  id String @id @default(uuid())

  studentId String
  teacherId String?

  type   SessionType
  status SessionStatus
  startedAt DateTime?
  endedAt DateTime?
  createdAt DateTime @default(now())

  student StudentProfile @relation("StudentSessions", fields: [studentId], references: [id])

  teacher TeacherProfile? @relation("TeacherSessions", fields: [teacherId], references: [id])
  feedback Feedback?
}

// ── Referral System ─────────────────────────────────────────

enum ReferralType {
  STUDENT
  TEACHER
}

enum ReferralStatus {
  PENDING
  COMPLETED
  REWARDED
}

model Referral {
  id          String         @id @default(uuid())
  referrerId  String         // userId of who made the referral
  refereeId   String?        // userId of the person who signed up via referral
  type        ReferralType   @default(STUDENT)
  code        String         @unique // unique referral code
  status      ReferralStatus @default(PENDING)
  pointsGiven Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  referrer    User           @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referee     User?          @relation("RefereeReferrals", fields: [refereeId], references: [id])
}

// ── MCQ / Quiz System ────────────────────────────────────────

enum McqDifficulty {
  EASY
  MEDIUM
  HARD
}

model McqQuestion {
  id         String        @id @default(uuid())
  subjectId  String?
  chapterId  String?
  question   String
  options    String[]
  answer     String
  difficulty McqDifficulty @default(MEDIUM)
  createdAt  DateTime      @default(now())

  subject    Subjects?     @relation(fields: [subjectId], references: [id])
  attempts   McqAttempt[]
}

model McqAttempt {
  id           String      @id @default(uuid())
  studentId    String
  questionId   String
  selectedOpt  String
  isCorrect    Boolean
  createdAt    DateTime    @default(now())

  student      StudentProfile @relation(fields: [studentId], references: [id])
  question     McqQuestion    @relation(fields: [questionId], references: [id])
}

